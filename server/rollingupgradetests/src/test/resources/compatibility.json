{
  "compatibility": [
    {
      "version-from": "[16.0,16.1)",
      "version-to": "[16.1,)",
      "properties": {
        "org.infinispan.test.server.resp.forceStandaloneMode": "true"
      },
      "exceptions": [
        {
          "description": "RESP CLUSTER SLOTS/SHARDS commands don't work with INADDR_ANY socket bindings",
          "issue": "https://github.com/infinispan/infinispan/issues/16391",
          "test-failures": [
            {
              "test-class": "org.infinispan.server.rollingupgrade.DefaultRollingUpgradeTestIT",
              "test-methods": [
                "testRespClient"
              ]
            }
          ]
        },
        {
          "description": "Boolean indexed queries may be rewritten by Lucene and use more clauses internally",
          "issue": "https://github.com/infinispan/infinispan/issues/16477",
          "test-failures": [
            {
              "test-class": "org.infinispan.server.functional.hotrod.HotRodCacheQueries",
              "test-methods": [
                "testManyInClauses"
              ]
            }
          ]
        },
        {
          "description": "Legacy metrics are disabled by default",
          "issue": "https://github.com/infinispan/infinispan/issues/16392",
          "test-failures": []
        },
        {
          "description": "Aggregation on indexed field do not work with non-indexed cache",
          "issue": "https://github.com/infinispan/infinispan/issues/16761",
          "test-failures": [
            {
              "test-class": "org.infinispan.server.functional.hotrod.HotRodCacheQueries",
              "test-methods": [
                "testIteratorWithQueryAndProjections"
              ]
            }
          ]
        }
      ]
    },
    {
      "version-from": "[16.0,16.2)",
      "version-to": "[16.2,)",
      "exceptions": [
        {
          "description": "RESP encoding changed in 16.2 - values are now stored using the configured value media type",
          "issue": "https://github.com/infinispan/infinispan/issues/16981",
          "test-failures": [
            {
              "test-class": "org.infinispan.server.functional.resp.RespDistributedTest",
              "test-methods": [
                "testListOperations",
                "testHashOperations",
                "testBasicOperations",
                "testHyperLogLogOperations"
              ]
            },
            {
              "test-class": "org.infinispan.server.functional.resp.RespHashTest",
              "test-methods": [
                "testHashOperations",
                "testMixTypes",
                "testConcurrentOperations"
              ]
            },
            {
              "test-class": "org.infinispan.server.functional.resp.RespListTest",
              "test-methods": [
                "testMixTypes",
                "testConcurrentOperations",
                "testRPUSH"
              ]
            },
            {
              "test-class": "org.infinispan.server.functional.resp.RespSetTest",
              "test-methods": [
                "testMixTypes",
                "testConcurrentOperations",
                "testSetOperations"
              ]
            },
            {
              "test-class": "org.infinispan.server.functional.resp.RespSortedSetTest",
