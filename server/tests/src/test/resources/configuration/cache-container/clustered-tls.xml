<cache-container xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="urn:infinispan:config:16.3 https://infinispan.org/schemas/infinispan-config-fragment-16.3.xsd urn:infinispan:server:16.3 https://infinispan.org/schemas/infinispan-server-16.3.xsd"
                 xmlns="urn:infinispan:config:16.3"
                 name="default" statistics="true"
                 xmlns:server="urn:infinispan:server:16.3">
   <transport cluster="${infinispan.cluster.name:cluster}" stack="${infinispan.cluster.stack}" server:security-realm="cluster-transport"/>
   <serialization>
      <allow-list>
         <regex>.*</regex>
      </allow-list>
   </serialization>
   <metrics gauges="true" histograms="true" accurate-size="true" legacy="false" />
</cache-container>
