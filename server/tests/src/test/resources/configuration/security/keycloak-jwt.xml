<security xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="urn:infinispan:server:16.2 https://infinispan.org/schemas/infinispan-server-16.2.xsd"
          xmlns="urn:infinispan:server:16.2">
   <security-realms>
      <security-realm name="keycloak">
         <server-identities>
            <ssl>
               <truststore path="ca.pfx" password="secret"/>
            </ssl>
         </server-identities>
      </security-realm>
      <security-realm name="default">
         <token-realm name="infinispan" auth-server-url="https://keycloak-test:8443/auth/" client-id="infinispan-console" principal-claim="sub">
            <jwt client-ssl-context="keycloak" issuer="https://keycloak-test:8443/realms/infinispan" audience="account"/>
         </token-realm>
      </security-realm>
   </security-realms>
</security>
