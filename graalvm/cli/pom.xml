<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <groupId>org.infinispan</groupId>
        <artifactId>infinispan-graalvm-parent</artifactId>
        <version>16.3.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <artifactId>infinispan-graalvm-cli</artifactId>
    <name>Infinispan GraalVM CLI</name>

    <properties>
        <product.name>Infinispan</product.name>
        <package.output-name>${infinispan.brand.short-name}</package.output-name>
        <package.runner-suffix>-cli</package.runner-suffix>
        <cli.name>${package.output-name}${package.runner-suffix}</cli.name>
        <k8.cmd>kubectl</k8.cmd>
        <native.charsets>-H:+AddAllCharsets</native.charsets>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.infinispan</groupId>
            <artifactId>infinispan-cli-client</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>io.lettuce</groupId>
                    <artifactId>lettuce-core</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>org.openjdk.jmh</groupId>
            <artifactId>jmh-core</artifactId>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>org.infinispan</groupId>
            <artifactId>infinispan-core</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>org.jgroups</groupId>
                    <artifactId>jgroups</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>io.fabric8</groupId>
            <artifactId>kubernetes-client</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>org.yaml</groupId>
                    <artifactId>snakeyaml</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <dependency>
            <groupId>org.graalvm.sdk</groupId>
            <artifactId>graal-sdk</artifactId>
        </dependency>

        <!-- Test Dependencies -->
       <dependency>
          <groupId>org.infinispan</groupId>
          <artifactId>infinispan-cli-client</artifactId>
          <type>test-jar</type>

       </dependency>
        <dependency>
            <groupId>org.infinispan</groupId>
            <artifactId>infinispan-testing</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.infinispan</groupId>
            <artifactId>infinispan-server-testdriver-core</artifactId>
            <scope>test</scope>
            <exclusions>
                <exclusion>
                    <groupId>org.infinispan</groupId>
                    <artifactId>infinispan-jboss-marshalling</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>org.infinispan</groupId>
            <artifactId>infinispan-server-tests</artifactId>
            <type>test-jar</type>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.infinispan</groupId>
            <artifactId>infinispan-core</artifactId>
            <type>test-jar</type>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.infinispan</groupId>
            <artifactId>infinispan-server-rest</artifactId>
            <type>test-jar</type>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <profiles>
        <profile>
            <!--
               GraalVM does not support -H:+AddAllCharsets on Windows (JNIRegistrationSupport.makeShimLibrary fails)
               https://github.com/oracle/graal/issues/13948
            -->
            <id>windows</id>
            <activation>
                <os>
                    <family>windows</family>
                </os>
            </activation>
            <properties>
                <native.charsets>-H:-AddAllCharsets</native.charsets>
            </properties>
        </profile>
        <profile>
            <id>native</id>
            <dependencies>
                <dependency>
                    <groupId>org.apache.logging.log4j</groupId>
                    <artifactId>log4j-slf4j-impl</artifactId>
                    <scope>compile</scope>
                </dependency>
                <dependency>
                    <groupId>org.infinispan</groupId>
                    <artifactId>infinispan-commons-graalvm</artifactId>
                </dependency>
                <dependency>
                    <groupId>org.infinispan</groupId>
                    <artifactId>infinispan-core-graalvm</artifactId>
                </dependency>
            </dependencies>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <extensions>true</extensions>
                        <executions>
                            <execution>
                                <id>build-native</id>
                                <goals>
                                    <goal>compile-no-fork</goal>
                                </goals>
                                <phase>package</phase>
                            </execution>
                        </executions>
                        <configuration>
                            <mainClass>org.infinispan.cli.commands.CLI</mainClass>
                            <imageName>${cli.name}</imageName>
                            <fallback>false</fallback>
                            <buildArgs>
                                <buildArg>-J-Xmx${native.build.xmx}</buildArg>
                                <buildArg>-J-Djava.awt.headless=true</buildArg>
                                <buildArg>-J-Dsun.nio.ch.maxUpdateArraySize=100</buildArg>
                                <buildArg>-J-Dio.netty.tryReflectionSetAccessible=true</buildArg>
                                <buildArg>-J-Dio.netty.noUnsafe=false</buildArg>
                                <buildArg>-J-Dio.netty.leakDetection.level=DISABLED</buildArg>
                                <buildArg>-J-Dio.netty.allocator.maxOrder=3</buildArg>
                                <buildArg>--enable-native-access=ALL-UNNAMED</buildArg>
                                <buildArg>--enable-url-protocols=http,https</buildArg>
                                <buildArg>--enable-monitoring=heapdump,threaddump</buildArg>
                                <buildArg>--enable-sbom=false</buildArg>
                                <buildArg>--initialize-at-run-time=org.aesh.terminal.tty.impl.WinConsoleNative,org.aesh.terminal.tty.impl.WinSysTerminal</buildArg>
                                <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>
                                <buildArg>-H:+AllowFoldMethods</buildArg>
                                <buildArg>-H:+ReportExceptionStackTraces</buildArg>
                                <buildArg>${native.charsets}</buildArg>
                                <buildArg>-H:IncludeLocales=en-US</buildArg>
                                <buildArg>-H:-UnlockExperimentalVMOptions</buildArg>
                                <buildArg>--exclude-config</buildArg>
                                <buildArg>io\.netty\.netty-codec</buildArg>
                                <buildArg>/META-INF/native-image/io\.netty/netty-codec/generated/handlers/reflect-config\.json</buildArg>
                                <buildArg>--exclude-config</buildArg>
                                <buildArg>io\.netty\.netty-handler</buildArg>
                                <buildArg>/META-INF/native-image/io\.netty/netty-handler/generated/handlers/reflect-config\.json</buildArg>
                            </buildArgs>
                        </configuration>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-failsafe-plugin</artifactId>
                        <configuration>
                            <argLine>-Dorg.infinispan.test.server.driver=CONTAINER -Dorg.infinispan.test.server.dir=${project.basedir}/../../server/runtime/target/${infinispan.brand.prefix}-server-${infinispan.brand.version} -Dinfinispan.server.log.path=${project.build.directory} -Dinfinispan.cli.bin=${project.build.directory}/${cli.name}</argLine>
                            <forkCount>1</forkCount>
                            <threadCount>8</threadCount>
                            <parallel>none</parallel>
                            <redirectTestOutputToFile>false</redirectTestOutputToFile>
                            <reuseForks>true</reuseForks>
                            <trimStackTrace>false</trimStackTrace>
                            <useFile>false</useFile>
                            <systemPropertyVariables>
                                <infinispan.cluster.stack>tcp</infinispan.cluster.stack>
                            </systemPropertyVariables>
                            <reportNameSuffix>native</reportNameSuffix>
                        </configuration>
                        <executions>
                            <execution>
                                <goals>
                                    <goal>integration-test</goal>
                                    <goal>verify</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-assembly-plugin</artifactId>
                        <executions>
                            <execution>
                                <phase>package</phase>
                                <goals>
                                    <goal>single</goal>
                                </goals>
                                <configuration>
                                    <appendAssemblyId>false</appendAssemblyId>
                                    <descriptors>
                                        <descriptor>src/main/assembly/zip.xml</descriptor>
                                    </descriptors>
                                    <finalName>${infinispan.brand.short-name}-cli-${infinispan.brand.version}-${os.detected.classifier}</finalName>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
