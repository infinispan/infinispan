                  "max-forced-size": "30"
                }
              },
              "indexed-entities": [
                "TheEntity"
              ]
            }
          }
        },
        "indexed-fs-medium": {
          "distributed-cache": {
            "mode": "SYNC",
            "indexing": {
              "enabled": true,
              "path": "/temp",
