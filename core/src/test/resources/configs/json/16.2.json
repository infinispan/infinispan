{
  "infinispan": {
    "jgroups": {
      "stacks": {
        "udp-test": {
          "stack-file": {
            "path": "stacks/udp.xml"
          }
        },
        "tcp-test": {
          "stack-file": {
            "path": "stacks/tcp_mping/tcp1.xml"
          }
        },
        "mping": {
          "stack": {
            "TCP": {
              "send_buf_size": "640000",
              "thread_pool.max_threads": "25",
              "sock_conn_timeout": "300ms",
              "bundler_type": "transfer-queue",
              "port_range": "30",
              "thread_pool.keep_alive_time": "5s",
              "bind_port": "7800",
              "recv_buf_size": "20000000",
              "thread_pool.min_threads": "0"
            },
            "RED": null,
            "MPING": {
              "ip_ttl": "2",
              "mcast_port": "43366",
              "mcast_addr": "239.2.4.6",
              "num_discovery_runs": "3",
              "bind_addr": "127.0.0.1",
              "break_on_coord_rsp": "true"
            },
            "MERGE3": null,
            "FD_SOCK2": null,
            "FD-ALL3": {
              "interval": "1000",
              "timeout": "3000"
            },
            "VERIFY-SUSPECT2": {
              "timeout": "1s"
            },
            "pbcast.NAKACK2": {
              "xmit_interval": "200ms",
              "xmit_table_num_rows": "50",
              "use_mcast_xmit": "false",
              "max_xmit_req_size": "500",
              "xmit_table_msgs_per_row": "1024",
              "xmit_table_max_compaction_time": "30s"
            },
            "UNICAST3": {
              "conn_close_timeout": "5s",
              "xmit_interval": "200ms",
              "xmit_table_num_rows": "50",
              "max_xmit_req_size": "500",
              "xmit_table_msgs_per_row": "1024",
              "xmit_table_max_compaction_time": "30s"
            },
            "pbcast.STABLE": {
              "desired_avg_gossip": "2s",
              "max_bytes": "1M"
            },
            "pbcast.GMS": {
              "join_timeout": "2s",
              "print_local_addr": "false"
            },
            "UFC": {
              "min_threshold": "0.40",
              "max_credits": "4m"
            },
            "MFC": {
              "min_threshold": "0.40",
              "max_credits": "4m"
            },
            "FRAG4": null
          }
        },
        "mytcp": {
          "stack": {
            "extends": "tcp-test",
            "FD-ALL3": {
              "timeout": "3500",
              "stack.combine": "COMBINE"
            }
          }
        },
        "tcpgossip": {
          "stack": {
            "extends": "tcp-test",
            "MPING": {
              "stack.combine": "REMOVE"
            },
            "TCPGOSSIP": {
              "initial_hosts": "localhost[12001]",
              "stack.position": "RED",
              "stack.combine": "INSERT_AFTER"
            }
          }
        },
        "tcpfdhost": {
          "stack": {
            "extends": "tcp",
            "FD-HOST": {
              "stack.position": "FD_ALL3",
              "stack.combine": "REPLACE"
            }
          }
        },
        "xsite": {
          "stack": {
            "extends": "udp",
            "relay.RELAY2": {
              "site": "LON",
              "max_site_masters": "1000"
            },
            "remote-sites": {
              "default-stack": "tcpgossip",
              "cluster": "xsite",
              "remote-site": {
                "name": "NYC",
                "cluster": "xsite",
                "stack": "tcp"
              }
            }
          }
        }
      }
    },
    "threads": {
      "thread-factories": {
        "infinispan-factory": {
          "thread-factory": {
            "group-name": "infinispan",
            "thread-name-pattern": "%G %i",
            "priority": "5"
          }
        }
      },
      "thread-pools": {
        "infinispan-non-blocking": {
          "non-blocking-bounded-queue-thread-pool": {
            "thread-factory": "infinispan-factory"
          }
        },
        "infinispan-expiration": {
          "scheduled-thread-pool": {
            "thread-factory": "infinispan-factory"
          }
        },
        "infinispan-listener": {
          "blocking-bounded-queue-thread-pool": {
            "thread-factory": "infinispan-factory"
          }
        },
        "infinispan-blocking": {
          "blocking-bounded-queue-thread-pool": {
            "thread-factory": "infinispan-factory"
          }
        }
      }
    },
    "cache-container": {
      "name": "maximal",
      "shutdown-hook": "DONT_REGISTER",
      "statistics": "true",
      "non-blocking-executor": "infinispan-non-blocking",
      "expiration-executor": "infinispan-expiration",
      "listener-executor": "infinispan-listener",
      "blocking-executor": "infinispan-blocking",
      "transport": {
        "cluster": "maximal-cluster",
        "machine": "a",
        "rack": "b",
        "site": "c",
        "node-name": "a-node",
        "stack": "tcp",
        "lock-timeout": "120000",
        "initial-cluster-size": "4",
        "initial-cluster-timeout": "30000",
        "raft-members": "b-node a-node"
      },
      "security": {
        "authorization": {
          "audit-logger": "org.infinispan.security.audit.NullAuditLogger",
          "identity-role-mapper": null,
          "roles": {
            "peasant": {
              "role": {
                "permissions": [
                  "READ"
                ]
              }
            },
            "vavasour": {
              "role": {
                "permissions": [
                  "WRITE",
                  "READ"
                ]
              }
            },
            "king": {
              "role": {
                "permissions": [
                  "ALL"
                ]
              }
            },
            "vassal": {
              "role": {
                "permissions": [
                  "WRITE",
                  "READ",
                  "LISTEN"
                ]
              }
            }
          }
        }
      },
      "serialization": {
        "marshaller": "org.infinispan.marshall.TestObjectStreamMarshaller",
        "context-initializers": [
          "org.infinispan.marshall.UserSCIImpl"
        ],
        "allow-list": {
          "class": [
            "org.infinispan.test.data.Person"
          ],
          "regex": [
            "org.infinispan.test.data.*"
          ]
        }
      },
      "metrics": {
        "gauges": true,
        "histograms": true,
        "legacy": false
      },
      "jmx": {
        "enabled": true,
        "domain": "my-domain",
        "mbean-server-lookup": "org.infinispan.jmx.CustomMBeanServerPropertiesTest$TestLookup",
        "properties": {
          "key": "value"
        }
      },
      "global-state": {
        "unclean-shutdown-action": "FAIL",
        "persistent-location": {
          "path": "/tmp/persistentPath"
        },
        "shared-persistent-location": {
          "path": "/tmp/sharedPath"
        },
        "temporary-location": {
          "path": "/tmp/tmpPath"
        },
        "overlay-configuration-storage": null
      },
      "eviction-containers": {
        "max-count-container": {
          "name": "max-count",
          "count": "4181"
        },
        "max-size-container": {
          "name": "max-size",
          "size": "23MB"
        }
      },
      "caches": {
        "local": {
          "local-cache": {
            "aliases": [
              "0",
              "abc"
            ],
            "statistics": true,
            "encoding": {
              "key": {
                "media-type": "application/x-java-object"
              },
              "value": {
                "media-type": "application/x-java-object"
              }
            },
            "locking": {
              "concurrency-level": "2000",
              "isolation": "NONE",
              "acquire-timeout": "30000",
              "striping": true
            },
            "transaction": {
              "mode": "FULL_XA",
              "auto-commit": true,
              "stop-timeout": "60000",
              "locking": "OPTIMISTIC",
              "reaper-interval": "35000",
              "complete-timeout": "34000",
              "transaction-manager-lookup": "org.infinispan.transaction.lookup.JBossStandaloneJTAManagerLookup"
            },
            "expiration": {
              "lifespan": "10",
              "max-idle": "5",
              "interval": "10000"
            },
            "memory": {
              "max-count": "20000"
            },
            "persistence": {
              "passivation": false,
              "availability-interval": "2000",
              "connection-attempts": "5",
              "file-store": {
                "purge": false,
                "preload": true,
                "shared": false,
                "data": {
                  "path": "path"
                },
                "index": {
                  "path": "path"
                },
                "write-behind": {
                  "modification-queue-size": "2048",
                  "fail-silently": true
                },
                "properties": {
                  "test_property": "foo_bar"
                }
              }
            }
          }
        },
        "invalid": {
          "invalidation-cache": {
            "mode": "SYNC",
            "statistics": true,
            "locking": {
              "concurrency-level": "2500",
              "isolation": "READ_COMMITTED",
              "acquire-timeout": "30500",
              "striping": true
            },
            "transaction": {
              "mode": "BATCH",
              "stop-timeout": "60500",
              "locking": "OPTIMISTIC"
            },
            "expiration": {
              "lifespan": "11",
              "max-idle": "6",
              "interval": "10500"
            },
            "memory": {
              "max-count": "20500"
            }
          }
        },
        "repl": {
          "replicated-cache": {
            "segments": "16",
            "key-partitioner": "org.infinispan.distribution.ch.impl.RESPHashFunctionPartitioner",
