              "index-writer": {
                "commit-interval": "2000"
              },
              "indexed-entities": [
                "TheEntity"
              ]
            }
          }
        },
        "indexed-reindex-at-startup": {
          "distributed-cache": {
            "mode": "SYNC",
            "indexing": {
              "enabled": true,
              "storage": "local-heap",
              "startup-mode": "REINDEX",
              "index-reader": {},
              "indexed-entities": [
                "TheEntity"
              ]
            }
          }
        },
        "indexed-manual-indexing": {
          "distributed-cache": {
            "mode": "SYNC",
            "indexing": {
              "enabled": true,
              "indexing-mode": "MANUAL",
              "use-java-embedded-entities": true,
              "index-reader": {},
              "index-sharding": {
                "shards": "7"
              },
              "indexed-entities": [
                "TheEntity"
              ]
            }
          }
        },
        "disabled-tracing": {
          "replicated-cache": {
            "mode": "SYNC",
            "tracing": {
              "enabled": false
            }
          }
        },
        "custom-default-max-results": {
          "local-cache": {
            "query": {
              "default-max-results": "10",
              "hit-count-accuracy": "1000"
            }
          }
        },
        "dist": {
          "distributed-cache": {
            "owners": "4",
            "segments": "2",
            "key-partitioner": "org.infinispan.distribution.ch.impl.HashFunctionPartitioner",
            "l1-lifespan": "20m",
            "mode": "SYNC",
            "remote-timeout": "35s",
            "statistics": true,
            "backups": {
              "merge-policy": "ALWAYS_REMOVE",
              "max-cleanup-delay": "60000",
              "tombstone-map-size": "128000",
              "NYC": {
                "backup": {
                  "strategy": "SYNC",
                  "timeout": "12500",
                  "failure-policy": "WARN",
                  "state-transfer": {
                    "chunk-size": "600",
                    "timeout": "2400000"
                  }
                }
              },
              "SFO": {
                "backup": {
                  "strategy": "ASYNC",
                  "timeout": "13000",
                  "failure-policy": "IGNORE",
                  "state-transfer": {
                    "chunk-size": "128",
                    "mode": "AUTO"
                  }
                }
              },
              "LON": {
                "backup": {
                  "strategy": "SYNC",
                  "timeout": "13500",
                  "failure-policy": "FAIL",
                  "take-offline": {
                    "after-failures": "3",
                    "min-wait": "10000"
                  }
                }
              }
            },
            "backup-for": {
              "remote-cache": "users",
              "remote-site": "LON"
            },
            "locking": {
