              "acquire-timeout": "31000",
              "striping": true
            },
            "transaction": {
              "mode": "BATCH",
              "stop-timeout": "61000",
              "locking": "PESSIMISTIC"
            },
            "expiration": {
              "lifespan": "12",
              "max-idle": "7",
              "interval": "11000",
              "touch": "ASYNC"
            },
            "memory": {
              "max-count": "21000"
            },
            "state-transfer": {
              "enabled": false,
              "timeout": "60000",
              "chunk-size": "10000"
            }
          }
        },
        "indexed": {
          "distributed-cache": {
            "mode": "SYNC",
            "indexing": {
              "enabled": true,
              "index-reader": {},
              "indexed-entities": [
                "AnotherEntity",
                "TheEntity"
              ]
            }
          }
        },
        "indexed-memory": {
          "distributed-cache": {
            "mode": "SYNC",
            "indexing": {
              "enabled": true,
