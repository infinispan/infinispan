              },
              "indexed-entities": [
                "TheEntity"
              ]
            }
          }
        },
        "indexed-fs-full": {
          "distributed-cache": {
            "mode": "SYNC",
            "indexing": {
              "enabled": true,
              "storage": "filesystem",
              "path": "/temp",
              "index-reader": {
                "refresh-interval": "0"
              },
              "index-writer": {
                "commit-interval": "2000",
                "low-level-trace": false,
                "max-buffered-entries": "32",
                "queue-count": "40",
                "queue-size": "10000",
                "thread-pool-size": "8",
                "ram-buffer-size": "400",
                "index-merge": {
                  "calibrate-by-deletes": true,
                  "factor": "2",
                  "max-entries": "2000",
                  "min-size": "10",
