            },
            "expiration": {
              "lifespan": "13",
              "max-idle": "8",
              "interval": "11500",
              "touch": "SYNC"
            },
            "memory": {
              "max-count": "21500"
            },
            "state-transfer": {
              "enabled": true,
              "timeout": "60500",
              "chunk-size": "10500"
            },
            "partition-handling": {
              "when-split": "ALLOW_READS",
              "merge-policy": "PREFERRED_NON_NULL"
            }
          }
        },
