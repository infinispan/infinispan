<server xmlns="urn:infinispan:server:{schemaversion}">
   <security>
      <security-realms>
         <security-realm name="keycloak">
            <server-identities>
               <ssl>
                  <truststore path="keycloak-trust.pfx" password="secret"/>
               </ssl>
            </server-identities>
         </security-realm>
         <security-realm name="default">
            <token-realm name="token"
                         auth-server-url="https://oauth-server/auth/"
                         client-id="my-client"
                         principal-claim="sub">
               <jwt issuer="https://oauth-server/realms/my-realm"
                    audience="account"
                    client-ssl-context="keycloak"/>
            </token-realm>
         </security-realm>
      </security-realms>
   </security>
   <endpoints socket-binding="default" security-realm="default"/>
</server>
